# ---------------------------------------------------------------------------
# Eye Clinic London referral portal — environment configuration
# Copy this file to .env.local and fill in real values for your environment.
# Never commit .env.local or any file containing real secrets.
# ---------------------------------------------------------------------------

# Supabase project (Settings -> API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-side only, NEVER exposed to the browser.
# Used by server actions / route handlers that must bypass RLS in a
# controlled way (e.g. audit log writes, server-generated references).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket used for private clinical documents (created by migrations)
NEXT_PUBLIC_SUPABASE_DOCUMENTS_BUCKET=referral-documents

# Public site URL, used for building auth redirect links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Demo mode
# ---------------------------------------------------------------------------
# When true, the app serves fictional in-memory data and a simplified
# sign-in flow instead of talking to Supabase.
#
# You do NOT need to set this to try the app: lib/demo/config.ts#isDemoMode()
# automatically falls back to demo mode whenever NEXT_PUBLIC_SUPABASE_URL /
# NEXT_PUBLIC_SUPABASE_ANON_KEY above are not both set, in every environment
# (including production) — there's no real backend to protect if none is
# configured, so a fresh deploy with zero environment variables serves the
# safe fictional dataset instead of crashing every request.
#
# The variables below only matter once you've configured a REAL Supabase
# project above and still want to force demo mode on top of it (e.g. to
# demo the UI without touching real data). In that case:
# Safety: demo mode is ALSO gated in code so that it cannot silently
# activate against a real Supabase project in a production deployment —
# NODE_ENV=production forces demo mode off unless
# NEXT_PUBLIC_ALLOW_DEMO_IN_PRODUCTION is explicitly set to "true", which
# should only ever be done for a deliberately sandboxed demo deployment
# that no real patient data will touch.
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_ALLOW_DEMO_IN_PRODUCTION=false

# Staff team access code — demo mode only, NOT a real authentication
# mechanism. Real staff authentication is Supabase Auth + role claim.
# If left unset, demo mode falls back to "ecl-demo" (see
# lib/actions/auth-actions.ts) so the demo build works with zero config.
NEXT_PUBLIC_DEMO_STAFF_CODE=change-me-in-local-env
